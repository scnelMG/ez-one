APP_ENV=local
SERVER_PORT=8080

DB_HOST=localhost
DB_PORT=3306
DB_NAME=job_workspace
DB_USER=job_workspace
DB_PASSWORD=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MAIL_USERNAME=
MAIL_PASSWORD=

# OpenDART local data import. Keep the real key only in backend/.env.
OPENDART_API_KEY=your_opendart_api_key_here

# 공공데이터포털 API Key (국민연금 사업장 내역 등)
PUBLIC_DATA_API_KEY=your_public_data_api_key_here

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_TOKEN_ENCRYPTION_KEY=

# P2 only. Enable when Mattermost collection scope is approved.
# MM_WEBHOOK_SECRET=
